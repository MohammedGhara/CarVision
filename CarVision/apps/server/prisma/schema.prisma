generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  GARAGE
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  passwordHash  String
  role      Role     @default(CLIENT)
  /// Street or free-form address for garage location (Nearest Garage groundwork).
  address   String?
  /// WGS-84 latitude; null until set. Intended range when set: -90..90 (enforced in DB).
  latitude  Float?
  /// WGS-84 longitude; null until set. Intended range when set: -180..180 (enforced in DB).
  longitude Float?
  /// Short public blurb for garage discovery (CLIENT Garages list); GARAGE only, optional.
  garageDescription String?
  /// Free-text hours line, e.g. "Sun–Thu 08:00–17:00"; optional, no structured schedule.
  workingHoursText    String?
  /// Public phone for garage discovery / map (E.164 or local string).
  phone               String?
  /// Offered services as JSON array of strings, e.g. ["Diagnostics","Oil Change"].
  services            Json?
  /// Average rating 0–5 when available (optional; may be null until reviews exist).
  rating              Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resetToken        String?   
  resetTokenExpiry  DateTime?
  clientVehicles    Vehicle[] @relation("ClientVehicles")
  garageVehicles    Vehicle[] @relation("GarageVehicles")
  sentMessages      Message[] @relation("SenderMessages")
  receivedMessages  Message[] @relation("ReceiverMessages")
  marketplaceListings MarketplaceListing[]
  forumPosts          ForumPost[]
  forumComments       ForumComment[]
  forumPostLikes      ForumPostLike[]
  forumCommentLikes   ForumCommentLike[]
}

enum ForumPostStatus {
  OPEN
  SOLVED
}

/// Community forum thread (mini-Reddit style).
model ForumPost {
  id             String          @id @default(cuid())
  authorId       String
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title          String
  description    String          @db.Text
  category       String
  carBrand       String?
  carModel       String?
  carYear        Int?
  engineType     String?
  dtcCode        String?
  /// Optional photo (stored under /uploads; relative URL).
  imageUrl       String?
  status         ForumPostStatus @default(OPEN)
  likesCount     Int             @default(0)
  commentsCount  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  comments       ForumComment[]
  likes          ForumPostLike[]

  @@index([category, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([authorId])
}

model ForumComment {
  id          String   @id @default(cuid())
  postId      String
  post        ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  likesCount  Int      @default(0)
  isSolution  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  likes       ForumCommentLike[]

  @@index([postId, createdAt])
}

model ForumPostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model ForumCommentLike {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   ForumComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, commentId])
}

/// Garage-offered item or service on the in-app marketplace (Sprint 1: list, detail, CRUD for GARAGE).
model MarketplaceListing {
  id           String   @id @default(cuid())
  sellerId     String
  seller       User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title        String
  description  String   @default("")
  priceCents   Int
  compareAtPriceCents Int?
  imageUrl     String?
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sellerId])
  @@index([isActive, createdAt(sort: Desc)])
}

enum VehicleStatus {
  PENDING
  IN_FIXING
  DONE
}

model Vehicle {
  id          String        @id @default(cuid())
  make        String
  model       String
  year        Int?
  vin         String?
  licensePlate String?
  color       String?
  mileage     Int?
  notes       String?
  status      VehicleStatus @default(PENDING)
  ownerId     String
  owner       User          @relation("ClientVehicles", fields: [ownerId], references: [id], onDelete: Cascade)
  garageId    String?
  garage      User?         @relation("GarageVehicles", fields: [garageId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
}

model Message {
  id          String      @id @default(cuid())
  senderId    String
  sender      User        @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User        @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String
  type        MessageType @default(TEXT)
  read        Boolean     @default(false)
  fileName    String?
  fileUrl     String?
  mimeType    String?     // MIME type (e.g., image/jpeg, video/mp4, application/pdf)
  fileSize    Int?        // File size in bytes
  createdAt   DateTime    @default(now())
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  category  String?
  ipAddress String?
  userAgent String?
  userId    String?
  metadata  String?  // JSON string for additional data
  createdAt DateTime @default(now())
}
