{
  "name": "carvision-app",
  "version": "0.1.0",
  "private": true,
  "description": "CarVision dashboard (web) + TCP bridge to ELM327 simulator",
  "main": "apps/server/server.js",
  "scripts": {
    "prestart": "docker compose -f apps/server/docker-compose.yml up -d",
    "start": "node apps/server/server.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand",
    "dev": "node apps/server/server.js",
    "db:generate": "prisma generate --schema apps/server/prisma/schema.prisma",
    "db:push": "prisma db push --schema apps/server/prisma/schema.prisma",
    "db:sync": "prisma generate --schema apps/server/prisma/schema.prisma && prisma db push --schema apps/server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "prisma": "^6.18.0",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
  ,
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
